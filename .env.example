# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_personal_chat_id       # your numeric chat ID for reminders

# OpenRouter  (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key
# Any model slug from openrouter.ai/models — default is a cheap fast model
OPENROUTER_MODEL=openai/gpt-4o-mini

# Groq — free Whisper voice transcription (groq.com → free, no card needed)
GROQ_API_KEY=your_groq_api_key

# Notion
NOTION_API_KEY=your_notion_integration_token
NOTION_PARENT_PAGE_ID=your_notion_page_id    # page where the Tasks DB will be created

# App
WEBHOOK_URL=https://yourdomain.com           # public HTTPS URL for Telegram webhook
PORT=8000
SCHEDULER_INTERVAL=60                        # seconds between reminder checks
REMINDER_LEAD_MINUTES=15                     # how many minutes before due to remind
