# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_personal_chat_id

# OpenRouter  (openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini

# Groq — free Whisper voice transcription (console.groq.com)
GROQ_API_KEY=your_groq_api_key

# Notion
NOTION_API_KEY=your_notion_integration_token
NOTION_PARENT_PAGE_ID=your_notion_page_id

# Upstash Redis — get from Vercel dashboard → Storage → Create → Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Cron secret — make up any random string e.g. "mysecret123"
CRON_SECRET=your_random_secret_string
